# Drop this in /etc/neverskip-sync.env, mode 0600, owned by the neverskip user.
# Never commit. Never log.

# Auth value extracted from Chrome's `token` cookie after a fresh OTP login.
# Lasts ~11 months. Refresh with `make token-env` on the laptop that holds
# the logged-in Chrome session, then scp the new value over.
#
# Alternative: leave NEVERSKIP_TOKEN unset and use TOKEN_FILE below to point
# at a small file holding just the token. The service re-reads the file
# whenever its 5-second cache expires, so a future `make refresh-token`
# CLI can rotate the token without restarting the service.
NEVERSKIP_TOKEN=REPLACE_ME_LONG_BASE64_BLOB

# Optional path to a file holding the token (single line). If set, the file's
# contents override NEVERSKIP_TOKEN whenever the file exists and is non-empty.
# Typical value: /var/lib/neverskip-sync/current_token.txt
# TOKEN_FILE=/var/lib/neverskip-sync/current_token.txt

# Long random topic for ntfy.sh. Anyone with this can spam this device's
# notifications, so treat it as a secret. `openssl rand -hex 16` is a fine
# generator.
NTFY_TOPIC=REPLACE_ME_LONG_RANDOM_STRING

# Long random query-param secret for the ICS calendar URL. Anyone with the
# full URL can read your calendar — rotate this if you ever leak it.
# `openssl rand -hex 32` is a fine generator.
ICS_TOKEN=REPLACE_ME_LONG_RANDOM_STRING

# Host used in the VEVENT UID (so UIDs are globally unique). Optional —
# defaults to neverskip-sync.local. Set to whatever public domain you
# serve the calendar feed from.
# CALENDAR_HOST=your-domain.example

# Polling cadence. 15m is the documented sweet spot.
POLL_INTERVAL=15m

# Where SQLite lives. The service user must own this directory.
SQLITE_PATH=/var/lib/neverskip-sync/state.db

# Listen address for the internal HTTP server — nginx proxies to it.
LISTEN_ADDR=127.0.0.1:8080

# Log level: debug | info | warn | error
LOG_LEVEL=info

# Skip polling between 23:00 and 06:00 IST. Optional.
QUIET_HOURS=false
